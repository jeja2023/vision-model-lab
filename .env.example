# Vision Model Lab 环境变量示例
# 复制为 .env 后按本地或部署环境调整。
VMLAB_WORKSPACE=/app
VMLAB_METADATA_DB=artifacts/vision_model_lab.sqlite3
# 使用 PostgreSQL 元数据存储时，可改用下面的连接字符串。
# VMLAB_METADATA_DB=postgresql://user:password@db:5432/vision_model_lab
VMLAB_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VMLAB_SERVE_FRONTEND=true
VMLAB_FRONTEND_DIST=frontend/dist
VMLAB_MAX_PACKAGE_SCAN_FILES=500
VMLAB_MAX_UPLOAD_BYTES=524288000
VMLAB_STORAGE_BACKEND=local
VMLAB_STORAGE_URI=artifacts/object-store
# 使用 S3/MinIO 时，将 VMLAB_STORAGE_BACKEND 设置为 s3 或 minio，并使用类似 s3://bucket/prefix 的 URI。
# VMLAB_S3_ENDPOINT_URL=http://127.0.0.1:9000
# VMLAB_S3_REGION=us-east-1
# VMLAB_S3_ACCESS_KEY_ID=minioadmin
# VMLAB_S3_SECRET_ACCESS_KEY=minioadmin
VMLAB_PIPELINE_WORKERS=2
VMLAB_EXTERNAL_COMMAND_TIMEOUT_SECONDS=3600
VMLAB_EXTERNAL_COMMAND_LOG_MAX_CHARS=20000
VMLAB_ALLOW_SHELL_COMMANDS=false
# 在共享环境或生产环境中请设置高强度令牌。
# VMLAB_AUTH_TOKEN=change-me
